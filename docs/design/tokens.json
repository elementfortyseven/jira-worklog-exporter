{
  "$meta": {
    "name": "Jira Worklog Exporter — Design Tokens",
    "direction": "Technical / Mono",
    "source": "JWE Redesign.html + styles.css (resolved .jwe[data-variant=\"mono\"])",
    "ticket": "JWE-48",
    "consumedBy": "JWE-33 → jwe/gui/theme/tokens.py (SSOT)",
    "note": "Values are RESOLVED for the chosen Mono variant (base tokens with the mono overrides applied). Where QSS-Richtung.html shows lighter values, these win — the prototype is canonical.",
    "version": "1.0.0",
    "updated": "2026-06-19"
  },
  "color": {
    "bg": {
      "canvas":      "#060B13",
      "window":      "#05090F",
      "card":        "#0A1019",
      "card2":       "#0B121C",
      "input":       "#060C14",
      "inputFocus":  "#0C1826"
    },
    "line": {
      "hairline":  "rgba(120,160,200,0.16)",
      "soft":      "rgba(120,160,200,0.08)",
      "strong":    "rgba(126,166,206,0.22)"
    },
    "text": {
      "primary":    "#E9EFF7",
      "secondary":  "#93A4BA",
      "tertiary":   "#5B6D82"
    },
    "accent": {
      "base":  "#22D3EE",
      "bright":"#4EE6F7",
      "deep":  "#0E7C91",
      "ink":   "#03171C"
    },
    "status": {
      "ok":   "#34D399",
      "warn": "#FBBF24",
      "err":  "#FB7185"
    }
  },
  "radius": {
    "control": 4,
    "card":    6,
    "window":  10,
    "_baselineRestrained": { "control": 8, "card": 12, "window": 16 }
  },
  "space": {
    "windowPadding":  22,
    "sectionGap":     16,
    "fieldGap":       14,
    "labelGap":       6,
    "cardPadding":    "18px 20px 20px"
  },
  "font": {
    "sans": "\"Segoe UI\", \"Helvetica Neue\", Helvetica, Arial, system-ui, sans-serif",
    "mono": "\"JetBrains Mono\", ui-monospace, \"SF Mono\", \"Cascadia Code\", Menlo, monospace"
  },
  "type": {
    "body":         { "family": "mono", "size": 12, "weight": 400, "_note": "Mono variant: input/field text is JetBrains Mono 12px. Base sans body = 13px." },
    "sectionTitle": { "family": "sans", "size": 15, "weight": 600 },
    "sectionSub":   { "family": "sans", "size": 11.5, "weight": 400 },
    "label":        { "family": "mono", "size": 11, "weight": 600, "transform": "uppercase", "letterSpacing": "0.08em" },
    "value":        { "family": "mono", "size": 12, "weight": 400 },
    "log":          { "family": "mono", "size": 11.5, "weight": 400, "lineHeight": 1.7 },
    "counter":      { "family": "mono", "size": 19, "weight": 600, "numeric": "tabular-nums" },
    "counterLabel": { "family": "sans", "size": 10, "weight": 600, "transform": "uppercase", "letterSpacing": "0.08em" },
    "titlebar":     { "family": "mono", "size": 12.5, "weight": 500 },
    "chip":         { "family": "mono", "size": 10.5, "weight": 500, "transform": "uppercase", "letterSpacing": "0.07em" }
  },
  "effect": {
    "focus":         { "web": "box-shadow: 0 0 0 1px rgba(34,211,238,0.45)", "qss": "border: 1px solid #22D3EE" },
    "windowShadow":  { "web": "0 40px 100px -30px rgba(0,0,0,0.8)", "qss": "QGraphicsDropShadowEffect(blurRadius=60, color=QColor(0,0,0,200), yOffset=20)" },
    "neonGlow":      { "web": "0 0 22px rgba(34,211,238,0.55)", "qss": "QGraphicsDropShadowEffect(blurRadius=22, color=QColor(34,211,238,140), offset=0)", "_note": "Optional — only on primary button / section icons / connection chip." },
    "scanline":      { "web": "repeating-linear-gradient(0deg, rgba(120,160,200,0.025) 0 1px, transparent 1px 3px)", "qss": "tiled QPixmap as widget background" }
  }
}
